// tool/akida_neuromorphic_module.hexa — M-AK (Akida neuromorphic helper module)
// @raw117_exempt — legacy module, 5-falsifier retrofit deferred to dedicated cycle
//
// 4-layer ω-cycle integration core helper. DESIGN-TIER 2026-05-01.
// Hardware (Raspberry Pi 5 + AKD1000 M.2 Akida Dev Kit) en route. Until
// physical arrival every io_seam returns a deterministic mock fixture so
// downstream selftests pass without claude binary calls or live SDK invoke.
//
// raw refs: raw 9 hexa-only (Akida MetaTF SDK invocation is an external
// tool — io_seam isolates it cleanly), raw 91 honest C3 (mock-tier disclosed
// in selftest banner), raw 169 surgical (single helper, no policy spillage),
// raw 247 r45 pure-fn / io-seam separation (4 pure-fn + 2 io-seam).
//
// Surfaces (consumed by qrng-bridge / γ-bridge / dispatch / RM4-step10 / M9):
//   @pure_fn classify_akida_capability(probe_output)
//                       -> [aks_count, sdk_version, model_loaded]
//   @pure_fn build_akida_inference_cmd(model_id, input_path)
//                       -> str
//   @pure_fn parse_spike_entropy_byte(metatf_spike_line)
//                       -> [byte_value, source_tag]
//   @pure_fn classify_task_suitability(purpose, payload_kind)
//                       -> str    // "akida" | "claude" | "either"
//   @io_seam akida_invoke(cmd)                  -> [stdout, rc]
//   @io_seam read_metatf_info()                 -> str
//
// Selftest: F1-F6, all pure (no live SDK). HARD: real Akida call count = 0
// until hardware lands.
//
// @tool(slug="akida_neuromorphic_module", desc="M-AK Akida neuromorphic core helper. 4 pure-fn + 2 io-seam. capability classify / inference cmd build / spike entropy parse / task suitability. Mock-tier until AKD1000 hardware arrives. raw 247 pure-fn/io-seam discipline.")
// @usage(hexa run tool/akida_neuromorphic_module.hexa --selftest)
// @usage(hexa run tool/akida_neuromorphic_module.hexa --classify <probe-file>)
// @usage(hexa run tool/akida_neuromorphic_module.hexa --suitability --purpose <p> --kind <k>)
// @design-tier 2026-05-01
// @raw-refs raw_9 raw_91 raw_169 raw_247

use std::env
use std::process

// ─── pure-fn 1 — classify_akida_capability ────────────────────────────
//
// Input: stdout from `akida ls` or `metatf-info --json`. Format example:
//   "AKD1000 device 0  pcie 0000:01:00.0  metatf 2.4.0  model=mobilenet_v1"
// or `--json` form:
//   {"devices":1,"sdk":"2.4.0","model":"mobilenet_v1"}
//
// Output: [aks_count, sdk_version, model_loaded]
// On parse failure → [0, "unknown", "none"] (never invents).
@pure_fn
fn classify_akida_capability(probe_output: str) -> array {
    let s = probe_output.trim()
    if s == "" { return [0, "unknown", "none"] }
    // Heuristic: count "AKD1000" tokens for device count.
    let mut count = 0
    let lower = s.to_lower()
    let mut idx = 0
    while idx < len(lower) {
        let rest = lower.slice(idx, len(lower))
        if rest.starts_with("akd1000") { count = count + 1 }
        idx = idx + 1
    }
    // Extract sdk= or "metatf X.Y.Z" token. Best-effort substring scan.
    let mut sdk = "unknown"
    if lower.contains("metatf") {
        let after = _slice_after(lower, "metatf")
        let head = _first_token(after)
        if head != "" { sdk = head }
    }
    let mut model = "none"
    if lower.contains("model=") {
        let after = _slice_after(lower, "model=")
        let head = _first_token(after)
        if head != "" { model = head }
    }
    return [count, sdk, model]
}

@pure_fn
fn _slice_after(s: str, needle: str) -> str {
    let n = len(needle)
    let mut i = 0
    while i + n <= len(s) {
        if s.slice(i, i + n) == needle { return s.slice(i + n, len(s)) }
        i = i + 1
    }
    return ""
}

@pure_fn
fn _first_token(s: str) -> str {
    let t = s.trim_start()
    let mut i = 0
    while i < len(t) {
        let ch = t.slice(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "," || ch == "}" || ch == "\"" {
            return t.slice(0, i)
        }
        i = i + 1
    }
    return t
}

// ─── pure-fn 2 — build_akida_inference_cmd ────────────────────────────
//
// Returns the deterministic shell-safe command string for invoking a
// MetaTF inference round. NEVER executes — pure builder. Caller passes
// through @io_seam akida_invoke().
//
// Whitelisted model_id pattern: [a-z0-9_-]+. Reject otherwise.
@pure_fn
fn build_akida_inference_cmd(model_id: str, input_path: str) -> str {
    if !_is_safe_model_id(model_id) { return "" }
    if input_path == "" { return "" }
    // Note: $HIVE shell quoting handled by caller's _shq before exec.
    return "akida-infer --model " + model_id + " --input " + input_path + " --json"
}

@pure_fn
fn _is_safe_model_id(s: str) -> bool {
    if s == "" { return false }
    let mut i = 0
    while i < len(s) {
        let ch = s.slice(i, i + 1)
        let ok = (ch >= "a" && ch <= "z") || (ch >= "0" && ch <= "9") || ch == "_" || ch == "-"
        if !ok { return false }
        i = i + 1
    }
    return true
}

// ─── pure-fn 3 — parse_spike_entropy_byte ─────────────────────────────
//
// Input: one line from MetaTF spike-event stream — e.g.
//   "spike t=12345.678ns neuron=42 layer=conv2 amp=0.83"
// Output: [byte_value 0..255, source_tag "akida_spike" | "akida_spike_fallback"]
// Strategy: hash three substring ranges of the line into a single byte.
// Determinism: identical line → identical byte. Salting handled by caller.
@pure_fn
fn parse_spike_entropy_byte(line: str) -> array {
    let s = line.trim()
    if s == "" { return [0, "akida_spike_fallback"] }
    // FNV-1a 8-bit fold.
    let mut h = 2166136261
    let mut i = 0
    while i < len(s) {
        let c = s.slice(i, i + 1)
        let code = _char_code(c)
        h = (h ^ code) * 16777619
        // Keep within int range.
        h = h & 4294967295
        i = i + 1
    }
    let byte = (h ^ (h >> 8) ^ (h >> 16) ^ (h >> 24)) & 255
    return [byte, "akida_spike"]
}

@pure_fn
fn _char_code(ch: str) -> int {
    if len(ch) == 0 { return 0 }
    return ch.byte_at(0)
}

// ─── pure-fn 4 — classify_task_suitability ────────────────────────────
//
// Layer-4 dispatch hint. purpose ∈ {kick, edge_inference, repl, health-probe}
// payload_kind ∈ {image, audio_clip, sensor_window, text_reasoning, mixed}
//
// Returns "akida" | "claude" | "either".
//   - edge_inference + (image|audio_clip|sensor_window) → akida
//   - text_reasoning                                    → claude
//   - mixed / unknown                                   → claude
//   - kick (general ω-cycle topic)                      → claude
@pure_fn
fn classify_task_suitability(purpose: str, payload_kind: str) -> str {
    if purpose == "edge_inference" {
        if payload_kind == "image" { return "akida" }
        if payload_kind == "audio_clip" { return "akida" }
        if payload_kind == "sensor_window" { return "akida" }
        return "either"
    }
    if payload_kind == "text_reasoning" { return "claude" }
    return "claude"
}

// ─── @io_seam 1 — akida_invoke ────────────────────────────────────────
//
// Until hardware lands, env AKIDA_HW_PRESENT=1 gates real exec.
// Mock returns a stable fixture line (selftest determinism).
@io_seam
fn akida_invoke(cmd: str) -> array {
    let hw = env("AKIDA_HW_PRESENT")
    if hw != "1" {
        // Mock fixture mirrors Layer-2 payload contract.
        let fixture = "{\"model\":\"mobilenet_v1\",\"top_class\":\"tabby_cat\",\"confidence\":0.91,\"latency_ms\":4}"
        return [fixture, 0]
    }
    let raw = exec(cmd + " 2>/dev/null")
    let rc = exec_rc()
    return [to_string(raw), rc]
}

// ─── @io_seam 2 — read_metatf_info ────────────────────────────────────
@io_seam
fn read_metatf_info() -> str {
    let hw = env("AKIDA_HW_PRESENT")
    if hw != "1" {
        // Mock — single device, MetaTF 2.4.0, default model unloaded.
        return "AKD1000 device 0  pcie 0000:01:00.0  metatf 2.4.0  model=none"
    }
    let raw = exec("metatf-info --json 2>/dev/null || akida ls 2>/dev/null")
    return to_string(raw).trim()
}

// ─── selftest ────────────────────────────────────────────────────────
fn selftest() -> int {
    let mut fails = 0
    println("[akida_neuromorphic_module selftest — DESIGN-TIER mock fixtures]")

    // F1: capability classify (mock fixture)
    let probe = read_metatf_info()
    let cap = classify_akida_capability(probe)
    if cap[0] >= 1 && cap[1] != "unknown" {
        println("  PASS F1 capability classify count=" + to_string(cap[0]) + " sdk=" + to_string(cap[1]))
    } else {
        println("  FAIL F1 capability classify"); fails = fails + 1
    }

    // F2: inference cmd build (whitelist)
    let cmd_ok = build_akida_inference_cmd("mobilenet_v1", "/tmp/img.bin")
    let cmd_bad = build_akida_inference_cmd("../etc/passwd", "/tmp/img.bin")
    if cmd_ok != "" && cmd_bad == "" {
        println("  PASS F2 inference cmd whitelist")
    } else {
        println("  FAIL F2 inference cmd whitelist"); fails = fails + 1
    }

    // F3: spike entropy byte (deterministic, range)
    let r1 = parse_spike_entropy_byte("spike t=1.0 neuron=1 layer=a amp=0.5")
    let r2 = parse_spike_entropy_byte("spike t=1.0 neuron=1 layer=a amp=0.5")
    if r1[0] == r2[0] && r1[0] >= 0 && r1[0] <= 255 && r1[1] == "akida_spike" {
        println("  PASS F3 spike entropy byte byte=" + to_string(r1[0]))
    } else {
        println("  FAIL F3 spike entropy byte"); fails = fails + 1
    }

    // F4: task suitability matrix
    let s_img = classify_task_suitability("edge_inference", "image")
    let s_text = classify_task_suitability("kick", "text_reasoning")
    if s_img == "akida" && s_text == "claude" {
        println("  PASS F4 task suitability dispatch")
    } else {
        println("  FAIL F4 task suitability"); fails = fails + 1
    }

    // F5: io_seam mock fallback (HW absent)
    let inv = akida_invoke("akida-infer --model mobilenet_v1 --input /tmp/x")
    if inv[1] == 0 && to_string(inv[0]).contains("mobilenet_v1") {
        println("  PASS F5 io_seam mock fallback")
    } else {
        println("  FAIL F5 io_seam mock fallback"); fails = fails + 1
    }

    // F6: empty / malformed input does not crash
    let cap0 = classify_akida_capability("")
    let r0 = parse_spike_entropy_byte("")
    if cap0[0] == 0 && r0[1] == "akida_spike_fallback" {
        println("  PASS F6 empty-input safety")
    } else {
        println("  FAIL F6 empty-input safety"); fails = fails + 1
    }

    if fails == 0 {
        println("[akida_neuromorphic_module] OK 6/6")
        return 0
    }
    println("[akida_neuromorphic_module] FAIL " + to_string(fails) + "/6")
    return 1
}

// ─── CLI surface ─────────────────────────────────────────────────────
fn main() -> int {
    let args = std::env::args()
    if len(args) >= 2 && args[1] == "--selftest" { return selftest() }
    if len(args) >= 3 && args[1] == "--classify" {
        // --classify <file>  reads & feeds classify_akida_capability.
        let raw = exec("cat " + args[2] + " 2>/dev/null")
        let cap = classify_akida_capability(to_string(raw))
        println("count=" + to_string(cap[0]) + " sdk=" + to_string(cap[1]) + " model=" + to_string(cap[2]))
        return 0
    }
    if len(args) >= 5 && args[1] == "--suitability" {
        // --suitability --purpose <p> --kind <k>
        let mut purpose = ""
        let mut kind = ""
        let mut i = 2
        while i < len(args) {
            if args[i] == "--purpose" && i + 1 < len(args) { purpose = args[i + 1] }
            if args[i] == "--kind" && i + 1 < len(args) { kind = args[i + 1] }
            i = i + 1
        }
        println(classify_task_suitability(purpose, kind))
        return 0
    }
    eprintln("usage: hexa run tool/akida_neuromorphic_module.hexa --selftest")
    eprintln("       hexa run tool/akida_neuromorphic_module.hexa --classify <probe-output-file>")
    eprintln("       hexa run tool/akida_neuromorphic_module.hexa --suitability --purpose <p> --kind <k>")
    return 2
}
