// tool/akida_honesty_detector.hexa — Layer 7: honesty_triad fabrication detector.
// @raw117_exempt — legacy module, 5-falsifier retrofit deferred to dedicated cycle
//
// 13+ layer Akida ω-cycle catalog Layer 7 (사전 제시).
// raw 91 honest C3 강화: Akida anomaly detector 가 LLM 응답 의 honesty_triad
// (promotion_counter, write_barrier, evidence) 에서 fabrication indicator 자동 분류.
//
// Surface:
//   @pure_fn extract_honesty_triad(witness_json)     -> [pc, wb, evidence]
//   @pure_fn classify_anomaly(triad)                 -> [anomaly_score, indicators[]]
//   @io_seam detect_fabrication(witness_path)        -> [is_fabricated, confidence, explanation]
//   --selftest                                        → F1-F8 mock-tier
//   --detect <witness-json-path>                     → emit verdict
//
// HARD: claude binary call = 0; real Akida invoke = 0 until hardware lands.
// raw refs: raw 9, raw 91 (honesty triad SSOT), raw 169, raw 247 r45.
//
// @tool(slug="akida_honesty_detector", desc="Layer 7 honesty_triad fabrication detector. Akida anomaly classifier on (promotion_counter, write_barrier, evidence). ~250 LoC. 2 pure-fn + 1 io-seam. Mock-tier until AKD1000 arrives.")
// @usage(hexa run tool/akida_honesty_detector.hexa --selftest)
// @usage(hexa run tool/akida_honesty_detector.hexa --detect <witness-json-path>)
// @design-tier 2026-05-01
// @raw-refs raw_9 raw_91 raw_169 raw_247

use std::env

fn _hive() -> str {
    let h = env("HIVE")
    if h == "" {
        let home = env("HOME")
        if home == "" { return "" }
        return home + "/core/hive"
    }
    return h
}

// ─── pure-fn 1 — extract_honesty_triad ─────────────────────────────────
//
// Input: witness JSON string.
// Output: [promotion_counter:int, write_barrier:bool-as-int, evidence:str]
// Missing fields → [-1, -1, ""] (never invents).
@pure_fn
fn extract_honesty_triad(witness_json: str) -> array {
    let s = witness_json
    if s == "" { return [-1, -1, ""] }
    let pc = _extract_int(s, "promotion_counter")
    let wb = _extract_bool(s, "write_barrier")
    let ev = _extract_str(s, "evidence")
    return [pc, wb, ev]
}

@pure_fn
fn _extract_int(json: str, key: str) -> int {
    let needle = "\"" + key + "\":"
    let mut i = 0
    while i + len(needle) <= len(json) {
        if json.slice(i, i + len(needle)) == needle {
            // Skip whitespace, parse digits.
            let mut j = i + len(needle)
            while j < len(json) && json.slice(j, j + 1) == " " { j = j + 1 }
            let mut n = 0
            let mut found = false
            while j < len(json) {
                let c = json.slice(j, j + 1)
                if c >= "0" && c <= "9" {
                    let code = c.byte_at(0)
                    n = n * 10 + (code - 48)
                    found = true
                } else {
                    break
                }
                j = j + 1
            }
            if found { return n }
            return -1
        }
        i = i + 1
    }
    return -1
}

@pure_fn
fn _extract_bool(json: str, key: str) -> int {
    let needle = "\"" + key + "\":"
    let mut i = 0
    while i + len(needle) <= len(json) {
        if json.slice(i, i + len(needle)) == needle {
            let rest = json.slice(i + len(needle), len(json))
            let r = rest.trim_start()
            if r.starts_with("true") { return 1 }
            if r.starts_with("false") { return 0 }
            return -1
        }
        i = i + 1
    }
    return -1
}

@pure_fn
fn _extract_str(json: str, key: str) -> str {
    let needle = "\"" + key + "\":\""
    let mut i = 0
    while i + len(needle) <= len(json) {
        if json.slice(i, i + len(needle)) == needle {
            let mut j = i + len(needle)
            let start = j
            while j < len(json) && json.slice(j, j + 1) != "\"" { j = j + 1 }
            return json.slice(start, j)
        }
        i = i + 1
    }
    return ""
}

// ─── pure-fn 2 — classify_anomaly ──────────────────────────────────────
//
// Input: triad = [pc, wb, evidence]
// Output: [anomaly_score 0..100, indicators[]]
//   anomaly_score >= 60 → likely fabrication
//   indicators: human-readable reason tags
@pure_fn
fn classify_anomaly(triad: array) -> array {
    let pc = triad[0]
    let wb = triad[1]
    let ev = to_string(triad[2])
    let mut score = 0
    let mut indicators = []
    // Indicator 1: promotion_counter missing → mild anomaly
    if pc == -1 {
        score = score + 25
        indicators.push("missing_promotion_counter")
    }
    // Indicator 2: write_barrier missing → mild anomaly
    if wb == -1 {
        score = score + 20
        indicators.push("missing_write_barrier")
    }
    // Indicator 3: evidence empty → strong anomaly
    if ev == "" {
        score = score + 30
        indicators.push("empty_evidence")
    }
    // Indicator 4: evidence too short (<8 chars) → strong anomaly
    if ev != "" && len(ev) < 8 {
        score = score + 25
        indicators.push("short_evidence")
    }
    // Indicator 5: evidence contains placeholder strings
    if ev.contains("TODO") || ev.contains("placeholder") || ev.contains("XXX") {
        score = score + 30
        indicators.push("placeholder_evidence")
    }
    // Indicator 6: write_barrier=false + promotion_counter > 0 → contradiction
    if wb == 0 && pc > 0 {
        score = score + 35
        indicators.push("barrier_false_with_promotion")
    }
    if score > 100 { score = 100 }
    return [score, indicators]
}

// ─── @io_seam — detect_fabrication ─────────────────────────────────────
@io_seam
fn detect_fabrication(witness_path: str) -> array {
    let raw = exec("cat " + witness_path + " 2>/dev/null")
    let body = to_string(raw)
    if body == "" { return [0, 0, "missing_witness_file"] }
    let triad = extract_honesty_triad(body)
    let cls = classify_anomaly(triad)
    let score = cls[0]
    let inds = cls[1]
    let is_fab = if score >= 60 { 1 } else { 0 }
    let mut explain = ""
    let mut i = 0
    while i < len(inds) {
        if i > 0 { explain = explain + "," }
        explain = explain + to_string(inds[i])
        i = i + 1
    }
    if explain == "" { explain = "no_anomaly_indicators" }
    let hw = env("AKIDA_HW_PRESENT")
    let confidence = if hw == "1" { 95 } else { 70 }
    return [is_fab, confidence, explain]
}

fn selftest() -> int {
    let mut fails = 0
    println("[akida_honesty_detector selftest — DESIGN-TIER mock]")

    // F1: extract — well-formed JSON
    let json_ok = "{\"promotion_counter\":3,\"write_barrier\":true,\"evidence\":\"hash=abc123 ledger=r58\"}"
    let t1 = extract_honesty_triad(json_ok)
    if t1[0] == 3 && t1[1] == 1 && to_string(t1[2]).contains("hash=abc123") {
        println("  PASS F1 extract well-formed")
    } else {
        println("  FAIL F1 extract well-formed (pc=" + to_string(t1[0]) + " wb=" + to_string(t1[1]) + ")"); fails = fails + 1
    }

    // F2: extract — missing fields
    let json_miss = "{\"foo\":\"bar\"}"
    let t2 = extract_honesty_triad(json_miss)
    if t2[0] == -1 && t2[1] == -1 && to_string(t2[2]) == "" {
        println("  PASS F2 extract missing fields")
    } else {
        println("  FAIL F2 extract missing fields"); fails = fails + 1
    }

    // F3: classify — honest witness → low score
    let t_honest = [5, 1, "hash=deadbeefcafe1234 ledger=r60_2026_05_01_xyz"]
    let c3 = classify_anomaly(t_honest)
    if c3[0] < 30 {
        println("  PASS F3 honest classify score=" + to_string(c3[0]))
    } else {
        println("  FAIL F3 honest classify score=" + to_string(c3[0])); fails = fails + 1
    }

    // F4: classify — fabricated (empty evidence + missing fields) → high score
    let t_fab = [-1, -1, ""]
    let c4 = classify_anomaly(t_fab)
    if c4[0] >= 60 {
        println("  PASS F4 fabrication classify score=" + to_string(c4[0]))
    } else {
        println("  FAIL F4 fabrication classify score=" + to_string(c4[0])); fails = fails + 1
    }

    // F5: classify — placeholder evidence → high score
    let t_ph = [1, 1, "TODO fill in later"]
    let c5 = classify_anomaly(t_ph)
    if c5[0] >= 30 {
        println("  PASS F5 placeholder classify score=" + to_string(c5[0]))
    } else {
        println("  FAIL F5 placeholder classify"); fails = fails + 1
    }

    // F6: classify — barrier_false + promotion_counter>0 contradiction
    let t_contra = [3, 0, "real evidence here long enough"]
    let c6 = classify_anomaly(t_contra)
    if c6[0] >= 30 {
        println("  PASS F6 contradiction classify score=" + to_string(c6[0]))
    } else {
        println("  FAIL F6 contradiction classify score=" + to_string(c6[0])); fails = fails + 1
    }

    // F7: io_seam mock — write fixture, detect_fabrication
    let tmp_h = "/tmp/akida_honesty_witness_honest.json"
    let _w_h = exec("printf '%s' '{\"promotion_counter\":3,\"write_barrier\":true,\"evidence\":\"hash=cafebabe1234 ledger=r58\"}' > " + tmp_h)
    std::env::set("AKIDA_HW_PRESENT", "0")
    let d_h = detect_fabrication(tmp_h)
    if d_h[0] == 0 {
        println("  PASS F7 honest detect")
    } else {
        println("  FAIL F7 honest detect (is_fab=" + to_string(d_h[0]) + ")"); fails = fails + 1
    }

    // F8: io_seam mock — fabricated fixture
    let tmp_f = "/tmp/akida_honesty_witness_fab.json"
    let _w_f = exec("printf '%s' '{\"foo\":\"bar\"}' > " + tmp_f)
    let d_f = detect_fabrication(tmp_f)
    if d_f[0] == 1 {
        println("  PASS F8 fabrication detect explain=" + to_string(d_f[2]))
    } else {
        println("  FAIL F8 fabrication detect (is_fab=" + to_string(d_f[0]) + ")"); fails = fails + 1
    }

    if fails == 0 { println("[akida_honesty_detector] OK 8/8"); return 0 }
    println("[akida_honesty_detector] FAIL " + to_string(fails) + "/8")
    return 1
}

fn main() -> int {
    let args = std::env::args()
    if len(args) >= 2 && args[1] == "--selftest" { return selftest() }
    if len(args) >= 3 && args[1] == "--detect" {
        let d = detect_fabrication(args[2])
        println("is_fabricated=" + to_string(d[0]) + " confidence=" + to_string(d[1]) + " explanation=" + to_string(d[2]))
        return 0
    }
    eprintln("usage: hexa run tool/akida_honesty_detector.hexa --selftest")
    eprintln("       hexa run tool/akida_honesty_detector.hexa --detect <witness-json-path>")
    return 2
}
