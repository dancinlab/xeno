// tool/akida_bridge_fact_verify.hexa — Layer 9: γ bridge fact cross-reference HW.
// @raw117_exempt — legacy module, 5-falsifier retrofit deferred to dedicated cycle
//
// 13+ layer Akida ω-cycle catalog Layer 9 (사전 제시).
// raw 73 deterministic verifier 보완: γ bridge 의 fact (web-fetch / search result)
// 을 Akida classifier 로 cross-reference 하여 supporting/contradicting source 분류.
//
// Surface:
//   @pure_fn extract_bridge_fact(bridge_payload)            -> [claim, source]
//   @pure_fn classify_fact_verify(claim, cross_ref)         -> [verified, confidence]
//   @io_seam cross_reference(bridge_payload, sources_csv)   -> [verdict, supporting_count]
//   --selftest                                                → F1-F6 mock-tier
//   --verify --payload <json> --sources <csv>                → emit verdict
//
// HARD: claude binary call = 0; real Akida invoke = 0 until hardware lands.
// raw refs: raw 9, raw 73, raw 91, raw 169, raw 247 r45.
//
// @tool(slug="akida_bridge_fact_verify", desc="Layer 9 γ bridge fact cross-reference. Akida classifier supporting/contradicting source split. ~200 LoC. 2 pure-fn + 1 io-seam. Mock-tier until AKD1000 arrives.")
// @usage(hexa run tool/akida_bridge_fact_verify.hexa --selftest)
// @usage(hexa run tool/akida_bridge_fact_verify.hexa --verify --payload <json> --sources <csv>)
// @design-tier 2026-05-01
// @raw-refs raw_9 raw_73 raw_91 raw_169 raw_247

use std::env

fn _hive() -> str {
    let h = env("HIVE")
    if h == "" {
        let home = env("HOME")
        if home == "" { return "" }
        return home + "/core/hive"
    }
    return h
}

// ─── pure-fn 1 — extract_bridge_fact ────────────────────────────────────
//
// Input: bridge payload JSON-ish string.
// Output: [claim, source]
@pure_fn
fn extract_bridge_fact(bridge_payload: str) -> array {
    let s = bridge_payload
    if s == "" { return ["", ""] }
    let claim = _extract_str_b(s, "claim")
    let source = _extract_str_b(s, "source")
    return [claim, source]
}

@pure_fn
fn _extract_str_b(json: str, key: str) -> str {
    let needle = "\"" + key + "\":\""
    let mut i = 0
    while i + len(needle) <= len(json) {
        if json.slice(i, i + len(needle)) == needle {
            let mut j = i + len(needle)
            let start = j
            while j < len(json) && json.slice(j, j + 1) != "\"" { j = j + 1 }
            return json.slice(start, j)
        }
        i = i + 1
    }
    return ""
}

// ─── pure-fn 2 — classify_fact_verify ──────────────────────────────────
//
// Heuristic: count substring matches between claim's tokens and cross_ref text.
// Returns [verified:bool-as-int, confidence 0..100].
@pure_fn
fn classify_fact_verify(claim: str, cross_ref: str) -> array {
    if claim == "" { return [0, 0] }
    if cross_ref == "" { return [0, 10] }
    // Tokenize claim by space, count tokens present in cross_ref.
    let toks = claim.split(" ")
    let mut hits = 0
    let mut total = 0
    let mut i = 0
    while i < len(toks) {
        let t = to_string(toks[i]).trim()
        if len(t) >= 4 {
            total = total + 1
            if cross_ref.contains(t) { hits = hits + 1 }
        }
        i = i + 1
    }
    if total == 0 { return [0, 10] }
    let pct = (hits * 100) / total
    let verified = if pct >= 50 { 1 } else { 0 }
    return [verified, pct]
}

// ─── @io_seam — cross_reference ────────────────────────────────────────
@io_seam
fn cross_reference(bridge_payload: str, sources_csv: str) -> array {
    let f = extract_bridge_fact(bridge_payload)
    let claim = to_string(f[0])
    if claim == "" { return ["UNKNOWN", 0] }
    let sources = sources_csv.split(",")
    let mut supporting = 0
    let mut total = 0
    let mut i = 0
    while i < len(sources) {
        let s = to_string(sources[i]).trim()
        if s != "" {
            total = total + 1
            let cls = classify_fact_verify(claim, s)
            if cls[0] == 1 { supporting = supporting + 1 }
        }
        i = i + 1
    }
    if total == 0 { return ["UNKNOWN", 0] }
    let verdict = if supporting * 2 >= total { "VERIFIED" } else { "CONTRADICTED" }
    let hw = env("AKIDA_HW_PRESENT")
    if hw == "1" {
        // Mark a real-Akida cross-ref pass — design-tier fall-through to mock.
    }
    return [verdict, supporting]
}

fn selftest() -> int {
    let mut fails = 0
    println("[akida_bridge_fact_verify selftest — DESIGN-TIER mock]")

    // F1: extract — well-formed
    let p1 = "{\"claim\":\"akida processor uses spike events\",\"source\":\"brainchip-docs\"}"
    let f1 = extract_bridge_fact(p1)
    if to_string(f1[0]).contains("spike events") && to_string(f1[1]) == "brainchip-docs" {
        println("  PASS F1 extract well-formed")
    } else {
        println("  FAIL F1 extract well-formed claim=" + to_string(f1[0])); fails = fails + 1
    }

    // F2: extract — empty safety
    let f2 = extract_bridge_fact("")
    if to_string(f2[0]) == "" && to_string(f2[1]) == "" {
        println("  PASS F2 extract empty safety")
    } else {
        println("  FAIL F2 extract empty safety"); fails = fails + 1
    }

    // F3: classify — strong support
    let c3 = classify_fact_verify("akida processor uses spike events native",
                                   "the akida processor architecture uses sparse spike events natively")
    if c3[0] == 1 && c3[1] >= 50 {
        println("  PASS F3 strong support pct=" + to_string(c3[1]))
    } else {
        println("  FAIL F3 strong support pct=" + to_string(c3[1])); fails = fails + 1
    }

    // F4: classify — contradiction (no shared tokens)
    let c4 = classify_fact_verify("akida spike events native processor",
                                   "lorem ipsum dolor sit amet")
    if c4[0] == 0 {
        println("  PASS F4 contradicted pct=" + to_string(c4[1]))
    } else {
        println("  FAIL F4 contradicted pct=" + to_string(c4[1])); fails = fails + 1
    }

    // F5: cross_reference — multi-source verified
    let p5 = "{\"claim\":\"akida processor uses spike events native\",\"source\":\"brainchip-docs\"}"
    let csv5 = "the akida processor architecture uses sparse spike events natively,akida is a processor that uses spike events native to its silicon"
    let v5 = cross_reference(p5, csv5)
    if to_string(v5[0]) == "VERIFIED" && v5[1] >= 1 {
        println("  PASS F5 multi-source verified supporting=" + to_string(v5[1]))
    } else {
        println("  FAIL F5 multi-source verified verdict=" + to_string(v5[0])); fails = fails + 1
    }

    // F6: cross_reference — contradicted across sources
    let p6 = "{\"claim\":\"akida processor uses spike events native\",\"source\":\"x\"}"
    let csv6 = "lorem ipsum,foo bar baz,nothing matches here at all"
    let v6 = cross_reference(p6, csv6)
    if to_string(v6[0]) == "CONTRADICTED" {
        println("  PASS F6 cross-source contradicted")
    } else {
        println("  FAIL F6 cross-source contradicted verdict=" + to_string(v6[0])); fails = fails + 1
    }

    if fails == 0 { println("[akida_bridge_fact_verify] OK 6/6"); return 0 }
    println("[akida_bridge_fact_verify] FAIL " + to_string(fails) + "/6")
    return 1
}

fn main() -> int {
    let args = std::env::args()
    if len(args) >= 2 && args[1] == "--selftest" { return selftest() }
    if len(args) >= 6 && args[1] == "--verify" {
        let mut payload = ""
        let mut sources = ""
        let mut i = 2
        while i < len(args) {
            if args[i] == "--payload" && i + 1 < len(args) { payload = args[i + 1] }
            if args[i] == "--sources" && i + 1 < len(args) { sources = args[i + 1] }
            i = i + 1
        }
        let v = cross_reference(payload, sources)
        println("verdict=" + to_string(v[0]) + " supporting=" + to_string(v[1]))
        return 0
    }
    eprintln("usage: hexa run tool/akida_bridge_fact_verify.hexa --selftest")
    eprintln("       hexa run tool/akida_bridge_fact_verify.hexa --verify --payload <json> --sources <csv>")
    return 2
}
