// tool/akida_theta_counterfactual.hexa — θ-counterfactual (LLM 발견 ablation layer).
// @raw117_exempt — legacy module, 5-falsifier retrofit deferred to dedicated cycle
//
// 13+ layer Akida ω-cycle catalog θ (LLM 발견, 2026-05-01).
// "θ counterfactual-replay layer (alpha-only, beta-only, gamma-only ablations)
//  must yield empirical axis correlation within ±0.10 of fan_out.correlation_estimate"
// (LLM 발견 falsifier condition, /tmp/kick_akida_meta.out).
//
// Strategy: re-run kick with each envelope independently zeroed; measure
// axis_a vs axis_b summary cosine; compare to declared correlation.
// 본 module 은 closed-form fixture 기반 — LLM call 0.
//
// Surface:
//   @pure_fn build_ablation_prompt(topic, mask)              -> str
//                  // mask ∈ "alpha_only" | "beta_only" | "gamma_only"
//   @pure_fn measure_correlation_diff(baseline, ablated)     -> int (×1000)
//   @io_seam run_ablation_study(topic)                       -> array<{mask, cor, diff}>
//   --selftest                                                → F1-F6 mock-tier
//   --ablation --topic <text>                                → emit study
//
// HARD: claude binary call = 0; real Akida invoke = 0 until hardware lands.
// raw refs: raw 9, raw 47 (envelope), raw 71, raw 91 (LLM 발견 honest disclosure),
// raw 117 falsifier preregistered, raw 169, raw 247 r45.
//
// @tool(slug="akida_theta_counterfactual", desc="θ-counterfactual ablation layer (LLM 발견). alpha-only/beta-only/gamma-only ablation study. ~280 LoC. 2 pure-fn + 1 io-seam. Closed-form fixtures, LLM call 0.")
// @usage(hexa run tool/akida_theta_counterfactual.hexa --selftest)
// @usage(hexa run tool/akida_theta_counterfactual.hexa --ablation --topic <text>)
// @design-tier 2026-05-01
// @raw-refs raw_9 raw_47 raw_71 raw_91 raw_117 raw_169 raw_247

use std::env

fn _hive() -> str {
    let h = env("HIVE")
    if h == "" {
        let home = env("HOME")
        if home == "" { return "" }
        return home + "/core/hive"
    }
    return h
}

// ─── pure-fn 1 — build_ablation_prompt ────────────────────────────────
@pure_fn
fn build_ablation_prompt(topic: str, mask: str) -> str {
    if topic == "" { return "" }
    if mask != "alpha_only" && mask != "beta_only" && mask != "gamma_only" {
        return ""
    }
    let mut suffix = ""
    if mask == "alpha_only" { suffix = "absorbed-only ablation: zero β qrng + γ bridge" }
    if mask == "beta_only"  { suffix = "qrng-only ablation: zero α absorbed + γ bridge" }
    if mask == "gamma_only" { suffix = "bridge-only ablation: zero α absorbed + β qrng" }
    return "kick topic=" + topic + " ablation_mask=" + mask + " | " + suffix
}

// ─── pure-fn 2 — measure_correlation_diff ─────────────────────────────
//
// Both baseline + ablated cosines as int×1000.
// Returns absolute diff (×1000).
@pure_fn
fn measure_correlation_diff(baseline: int, ablated: int) -> int {
    let d = baseline - ablated
    if d < 0 { return 0 - d }
    return d
}

// Pure-fn: closed-form ablation fixture. Returns cosine ×1000 for
// (topic, mask) without invoking any LLM.
// Strategy: hash(topic + mask) → bucket into [0,1000).
@pure_fn
fn _ablation_fixture_cosine(topic: str, mask: str) -> int {
    let s = topic + ":" + mask
    let mut h = 2166136261
    let mut i = 0
    while i < len(s) {
        let ch = s.slice(i, i + 1)
        let code = if len(ch) > 0 { ch.byte_at(0) } else { 0 }
        h = (h ^ code) * 16777619
        h = h & 4294967295
        i = i + 1
    }
    // Map to 200..900 (avoid extreme edges).
    let raw = h & 65535
    let band = 200 + (raw % 700)
    return band
}

// ─── @io_seam — run_ablation_study ─────────────────────────────────────
//
// Returns array of [mask, correlation_x1000, diff_from_baseline]
@io_seam
fn run_ablation_study(topic: str) -> array {
    if topic == "" { return [] }
    // Closed-form baseline cosine.
    let baseline = _ablation_fixture_cosine(topic, "baseline")
    let masks = ["alpha_only", "beta_only", "gamma_only"]
    let mut results = []
    let mut i = 0
    while i < len(masks) {
        let mask = to_string(masks[i])
        let cos = _ablation_fixture_cosine(topic, mask)
        let diff = measure_correlation_diff(baseline, cos)
        results.push([mask, cos, diff])
        i = i + 1
    }
    return results
}

fn selftest() -> int {
    let mut fails = 0
    println("[akida_theta_counterfactual selftest — DESIGN-TIER closed-form]")

    // F1: build_ablation_prompt — well-formed
    let p1 = build_ablation_prompt("akida-integration", "alpha_only")
    if p1 != "" && p1.contains("alpha_only") && p1.contains("absorbed-only") {
        println("  PASS F1 build_ablation_prompt alpha_only")
    } else {
        println("  FAIL F1 build_ablation_prompt"); fails = fails + 1
    }

    // F2: build_ablation_prompt — invalid mask rejected
    let p2 = build_ablation_prompt("akida-integration", "invalid_mask")
    if p2 == "" {
        println("  PASS F2 invalid mask rejected")
    } else {
        println("  FAIL F2 invalid mask rejected"); fails = fails + 1
    }

    // F3: measure_correlation_diff — symmetry
    let d_ab = measure_correlation_diff(420, 380)
    let d_ba = measure_correlation_diff(380, 420)
    if d_ab == 40 && d_ba == 40 {
        println("  PASS F3 diff symmetry")
    } else {
        println("  FAIL F3 diff symmetry ab=" + to_string(d_ab) + " ba=" + to_string(d_ba)); fails = fails + 1
    }

    // F4: closed-form fixture — deterministic
    let c1 = _ablation_fixture_cosine("topic-x", "alpha_only")
    let c2 = _ablation_fixture_cosine("topic-x", "alpha_only")
    if c1 == c2 && c1 >= 200 && c1 <= 900 {
        println("  PASS F4 fixture deterministic cos=" + to_string(c1))
    } else {
        println("  FAIL F4 fixture deterministic"); fails = fails + 1
    }

    // F5: run_ablation_study — 3 masks present
    let study = run_ablation_study("akida-integration-test")
    if len(study) == 3 {
        let m0 = to_string(study[0][0])
        let m1 = to_string(study[1][0])
        let m2 = to_string(study[2][0])
        if m0 == "alpha_only" && m1 == "beta_only" && m2 == "gamma_only" {
            println("  PASS F5 3-mask ablation study")
        } else {
            println("  FAIL F5 3-mask ablation study masks=" + m0 + "," + m1 + "," + m2); fails = fails + 1
        }
    } else {
        println("  FAIL F5 3-mask ablation study count=" + to_string(len(study))); fails = fails + 1
    }

    // F6: empty topic safety
    let study_empty = run_ablation_study("")
    if len(study_empty) == 0 {
        println("  PASS F6 empty-topic safety")
    } else {
        println("  FAIL F6 empty-topic safety"); fails = fails + 1
    }

    if fails == 0 { println("[akida_theta_counterfactual] OK 6/6"); return 0 }
    println("[akida_theta_counterfactual] FAIL " + to_string(fails) + "/6")
    return 1
}

fn main() -> int {
    let args = std::env::args()
    if len(args) >= 2 && args[1] == "--selftest" { return selftest() }
    if len(args) >= 4 && args[1] == "--ablation" {
        let mut topic = ""
        let mut i = 2
        while i < len(args) {
            if args[i] == "--topic" && i + 1 < len(args) { topic = args[i + 1] }
            i = i + 1
        }
        let study = run_ablation_study(topic)
        let mut k = 0
        while k < len(study) {
            let row = study[k]
            println("mask=" + to_string(row[0]) + " correlation_x1000=" + to_string(row[1]) + " diff=" + to_string(row[2]))
            k = k + 1
        }
        return 0
    }
    eprintln("usage: hexa run tool/akida_theta_counterfactual.hexa --selftest")
    eprintln("       hexa run tool/akida_theta_counterfactual.hexa --ablation --topic <text>")
    return 2
}
