// tool/akida_tier1_gate.hexa — Layer 6: tier_1 promotion gate via Akida classifier.
// @raw117_exempt — legacy module, 5-falsifier retrofit deferred to dedicated cycle
//
// 13+ layer Akida ω-cycle catalog Layer 6 (사전 제시).
// raw 71 design-strategy-falsifier-retire-rule + raw 73 deterministic verifier.
// falsifier_pass_pattern (예: "F1=PASS,F2=PASS,F3=FAIL") 을 hardware-side
// deterministic 검증 — Akida classifier 가 LLM 의 self-attest 를 echo verify.
//
// Surface:
//   @pure_fn parse_falsifier_pattern(pattern_str)        -> array<{id, verdict}>
//   @pure_fn verify_pattern_consistency(witness, pattern)-> bool
//   @io_seam hardware_verify_tier1(witness_path)         -> [verdict, confidence]
//   --selftest                                            → F1-F6 mock-tier
//   --verify <witness-json-path>                         → emit verdict
//
// HARD: claude binary call = 0; real Akida invoke = 0 until hardware lands.
// raw refs: raw 9 hexa-only, raw 71, raw 73, raw 91 (honest C3 mock disclosure),
// raw 169 surgical, raw 247 r45 pure/io split.
//
// @tool(slug="akida_tier1_gate", desc="Layer 6 tier_1 promotion gate. Akida classifier echo-verifies falsifier_pass_pattern. ~180 LoC. 2 pure-fn + 1 io-seam. Mock-tier until AKD1000 arrives.")
// @usage(hexa run tool/akida_tier1_gate.hexa --selftest)
// @usage(hexa run tool/akida_tier1_gate.hexa --verify <witness-json-path>)
// @design-tier 2026-05-01
// @raw-refs raw_9 raw_71 raw_73 raw_91 raw_247

use std::env

fn _hive() -> str {
    let h = env("HIVE")
    if h == "" {
        let home = env("HOME")
        if home == "" { return "" }
        return home + "/core/hive"
    }
    return h
}

// ─── pure-fn 1 — parse_falsifier_pattern ───────────────────────────────
//
// Input: "F1=PASS,F2=FAIL,F3=PASS"
// Output: array of [id, verdict] pairs. Empty/invalid → [].
@pure_fn
fn parse_falsifier_pattern(pattern_str: str) -> array {
    let s = pattern_str.trim()
    if s == "" { return [] }
    let parts = s.split(",")
    let mut out = []
    let mut i = 0
    while i < len(parts) {
        let p = to_string(parts[i]).trim()
        if p != "" {
            let kv = p.split("=")
            if len(kv) == 2 {
                let id = to_string(kv[0]).trim()
                let verdict = to_string(kv[1]).trim()
                if id != "" && (verdict == "PASS" || verdict == "FAIL") {
                    out.push([id, verdict])
                }
            }
        }
        i = i + 1
    }
    return out
}

// ─── pure-fn 2 — verify_pattern_consistency ────────────────────────────
//
// witness_json: simplified — substring scan for "F<N>=PASS|FAIL" tokens.
// pattern: parsed array (output of parse_falsifier_pattern).
// Returns true iff witness contains all id=verdict pairs from pattern.
@pure_fn
fn verify_pattern_consistency(witness: str, pattern: array) -> bool {
    if len(pattern) == 0 { return false }
    let mut i = 0
    while i < len(pattern) {
        let pair = pattern[i]
        let needle = to_string(pair[0]) + "=" + to_string(pair[1])
        if !witness.contains(needle) { return false }
        i = i + 1
    }
    return true
}

// ─── @io_seam — hardware_verify_tier1 ──────────────────────────────────
@io_seam
fn hardware_verify_tier1(witness_path: str) -> array {
    let hw = env("AKIDA_HW_PRESENT")
    if hw != "1" {
        // Mock: read the file, scan for F<N>=PASS pattern, derive a deterministic
        // verdict (PASS iff at least one F<N>=PASS substring AND no parse error).
        let raw = exec("cat " + witness_path + " 2>/dev/null")
        let body = to_string(raw)
        if body == "" { return ["UNKNOWN", 0] }
        if body.contains("=PASS") && !body.contains("PARSE_ERROR") {
            return ["PASS", 90]
        }
        return ["FAIL", 70]
    }
    // Real path: invoke Akida classifier on witness embedding.
    let cmd = "akida-classify --task tier1-gate --input " + witness_path + " --json"
    let raw = exec(cmd + " 2>/dev/null")
    let body = to_string(raw).trim()
    if body.contains("\"verdict\":\"PASS\"") { return ["PASS", 95] }
    if body.contains("\"verdict\":\"FAIL\"") { return ["FAIL", 85] }
    return ["UNKNOWN", 0]
}

fn selftest() -> int {
    let mut fails = 0
    println("[akida_tier1_gate selftest — DESIGN-TIER mock]")

    // F1: parse — well-formed pattern
    let p1 = parse_falsifier_pattern("F1=PASS,F2=FAIL,F3=PASS")
    if len(p1) == 3 && to_string(p1[0][0]) == "F1" && to_string(p1[1][1]) == "FAIL" {
        println("  PASS F1 parse well-formed")
    } else {
        println("  FAIL F1 parse well-formed (got len=" + to_string(len(p1)) + ")"); fails = fails + 1
    }

    // F2: parse — empty / malformed safety
    let p2 = parse_falsifier_pattern("")
    let p3 = parse_falsifier_pattern("garbage=stuff,F1=MAYBE")
    if len(p2) == 0 && len(p3) == 0 {
        println("  PASS F2 parse safety")
    } else {
        println("  FAIL F2 parse safety"); fails = fails + 1
    }

    // F3: consistency — witness contains all pattern entries
    let pat = parse_falsifier_pattern("F1=PASS,F2=FAIL")
    let w_ok = "{\"falsifiers\":\"F1=PASS,F2=FAIL,F3=PASS\"}"
    let w_bad = "{\"falsifiers\":\"F1=PASS,F2=PASS\"}"
    let v_ok = verify_pattern_consistency(w_ok, pat)
    let v_bad = verify_pattern_consistency(w_bad, pat)
    if v_ok && !v_bad {
        println("  PASS F3 verify consistency")
    } else {
        println("  FAIL F3 verify consistency ok=" + to_string(v_ok) + " bad=" + to_string(v_bad)); fails = fails + 1
    }

    // F4: io_seam mock — write a fixture, hardware_verify reads
    let tmp = "/tmp/akida_tier1_gate_witness.json"
    let w = exec("printf '%s' '{\"falsifiers\":\"F1=PASS,F2=FAIL\"}' > " + tmp)
    std::env::set("AKIDA_HW_PRESENT", "0")
    let v = hardware_verify_tier1(tmp)
    if to_string(v[0]) == "PASS" && v[1] >= 50 {
        println("  PASS F4 io_seam verify mock verdict=" + to_string(v[0]))
    } else {
        println("  FAIL F4 io_seam verify mock verdict=" + to_string(v[0])); fails = fails + 1
    }

    // F5: io_seam mock — missing file
    let v_nf = hardware_verify_tier1("/tmp/nonexistent-akida-witness-xyz.json")
    if to_string(v_nf[0]) == "UNKNOWN" {
        println("  PASS F5 missing-file safety")
    } else {
        println("  FAIL F5 missing-file safety verdict=" + to_string(v_nf[0])); fails = fails + 1
    }

    // F6: parse — single-entry tolerated
    let p6 = parse_falsifier_pattern("F1=PASS")
    if len(p6) == 1 && to_string(p6[0][0]) == "F1" {
        println("  PASS F6 parse single-entry")
    } else {
        println("  FAIL F6 parse single-entry"); fails = fails + 1
    }

    if fails == 0 { println("[akida_tier1_gate] OK 6/6"); return 0 }
    println("[akida_tier1_gate] FAIL " + to_string(fails) + "/6")
    return 1
}

fn main() -> int {
    let args = std::env::args()
    if len(args) >= 2 && args[1] == "--selftest" { return selftest() }
    if len(args) >= 3 && args[1] == "--verify" {
        let v = hardware_verify_tier1(args[2])
        println("verdict=" + to_string(v[0]) + " confidence=" + to_string(v[1]))
        return 0
    }
    eprintln("usage: hexa run tool/akida_tier1_gate.hexa --selftest")
    eprintln("       hexa run tool/akida_tier1_gate.hexa --verify <witness-json-path>")
    return 2
}
