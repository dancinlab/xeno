// tool/akida_delta_feedback.hexa — δ-feedback (LLM 발견 cross-stratum feedback layer).
// @raw117_exempt — legacy module, 5-falsifier retrofit deferred to dedicated cycle
//
// 13+ layer Akida ω-cycle catalog δ (LLM 발견, 2026-05-01).
// "δ cross-stratum feedback layer (witness-verdict → kernel-retune) must reduce
//  fan_out duplicate-axis-name rate by ≥20% over 5 consecutive cycles"
// (LLM 발견 falsifier condition, /tmp/kick_akida_meta.out).
//
// Cross-stratum: 한 cycle 의 witness verdict 가 다음 cycle 의 kernel parameter
// (axis seeding + correlation gate threshold + falsifier weight) 을 retune 한다.
//
// Surface:
//   @pure_fn extract_witness_verdict(witness_json)        -> [tier1, falsifier_pass, axes_quality]
//   @pure_fn compute_kernel_adjustments(verdict, prev)   -> kernel_diff
//   @io_seam retune_kernel(witness_path, kernel_path)    -> [new_kernel_json, applied_changes]
//   --selftest                                            → F1-F8 mock-tier (5-cycle simulation)
//   --retune --witness <p> --kernel <p>                  → run one retune step
//
// HARD: claude binary call = 0; real Akida invoke = 0 until hardware lands.
// raw refs: raw 9, raw 47, raw 71, raw 91 (LLM 발견 honest disclosure),
// raw 169, raw 247 r45.
//
// @tool(slug="akida_delta_feedback", desc="δ-feedback cross-stratum layer (LLM 발견). witness verdict → next-cycle kernel retune. ~280 LoC. 2 pure-fn + 1 io-seam. Mock-tier until AKD1000 arrives.")
// @usage(hexa run tool/akida_delta_feedback.hexa --selftest)
// @usage(hexa run tool/akida_delta_feedback.hexa --retune --witness <p> --kernel <p>)
// @design-tier 2026-05-01
// @raw-refs raw_9 raw_47 raw_71 raw_91 raw_169 raw_247

use std::env

fn _hive() -> str {
    let h = env("HIVE")
    if h == "" {
        let home = env("HOME")
        if home == "" { return "" }
        return home + "/core/hive"
    }
    return h
}

// ─── pure-fn 1 — extract_witness_verdict ───────────────────────────────
//
// Output: [tier1_pass:int, falsifier_pass_count:int, axes_quality 0..100]
@pure_fn
fn extract_witness_verdict(witness_json: str) -> array {
    let s = witness_json
    if s == "" { return [0, 0, 0] }
    let tier1 = if s.contains("\"tier1\":\"PASS\"") || s.contains("\"verdict\":\"PASS\"") { 1 } else { 0 }
    // Count "=PASS" occurrences as falsifier pass count.
    let mut fp_count = 0
    let mut i = 0
    while i + 5 <= len(s) {
        if s.slice(i, i + 5) == "=PASS" { fp_count = fp_count + 1 }
        i = i + 1
    }
    // Axes-quality proxy: count distinct "axis_a" + "axis_b" + summary len.
    let mut q = 0
    if s.contains("axis_a") { q = q + 30 }
    if s.contains("axis_b") { q = q + 30 }
    if s.contains("summary") { q = q + 20 }
    if s.contains("correlation_estimate") { q = q + 20 }
    if q > 100 { q = 100 }
    return [tier1, fp_count, q]
}

// ─── pure-fn 2 — compute_kernel_adjustments ────────────────────────────
//
// kernel_diff =
//   { axis_seed_strength_delta:int, correlation_threshold_delta:int (×1000),
//     falsifier_weight_delta:int, duplicate_axis_penalty_delta:int }
// Encoded as 4-int array.
@pure_fn
fn compute_kernel_adjustments(verdict: array, prev_kernel: array) -> array {
    let tier1 = verdict[0]
    let fp = verdict[1]
    let q = verdict[2]
    // Default deltas zero.
    let mut axis_seed_d = 0
    let mut corr_thr_d = 0
    let mut fals_w_d = 0
    let mut dup_pen_d = 0
    if tier1 == 0 {
        // Failed tier1 → strengthen axis seed + raise dup penalty.
        axis_seed_d = 5
        dup_pen_d = 10
    }
    if fp < 3 {
        // Insufficient falsifier coverage → raise falsifier weight.
        fals_w_d = 10
    }
    if q < 50 {
        // Low axes quality → tighten correlation threshold (lower it).
        corr_thr_d = -50    // ×1000 scale (0.05 lower)
    }
    if q >= 80 && tier1 == 1 {
        // High quality + pass → relax dup penalty slightly.
        dup_pen_d = -3
    }
    return [axis_seed_d, corr_thr_d, fals_w_d, dup_pen_d]
}

// Apply kernel diff to kernel state (4-int array).
@pure_fn
fn _apply_kernel_diff(prev: array, diff: array) -> array {
    let n = len(prev)
    if n != 4 || len(diff) != 4 {
        // Defensive: return prev unchanged.
        return prev
    }
    let mut out = [prev[0] + diff[0], prev[1] + diff[1], prev[2] + diff[2], prev[3] + diff[3]]
    return out
}

// ─── @io_seam — retune_kernel ──────────────────────────────────────────
@io_seam
fn retune_kernel(witness_path: str, kernel_state_path: str) -> array {
    let raw_w = exec("cat " + witness_path + " 2>/dev/null")
    let body = to_string(raw_w)
    if body == "" { return ["NO_WITNESS", []] }
    let verdict = extract_witness_verdict(body)
    // Read kernel state (simple format: 4 comma-sep ints) or default.
    let raw_k = exec("cat " + kernel_state_path + " 2>/dev/null")
    let k_body = to_string(raw_k).trim()
    let mut prev = [50, 700, 100, 30]   // axis_seed=50, corr_thr=0.700, fals_w=100, dup_pen=30
    if k_body != "" {
        let parts = k_body.split(",")
        if len(parts) == 4 {
            prev = [_atoi(to_string(parts[0])), _atoi(to_string(parts[1])),
                    _atoi(to_string(parts[2])), _atoi(to_string(parts[3]))]
        }
    }
    let diff = compute_kernel_adjustments(verdict, prev)
    let new_kernel = _apply_kernel_diff(prev, diff)
    return [_kernel_to_str(new_kernel), diff]
}

@pure_fn
fn _atoi(s: str) -> int {
    let t = s.trim()
    if t == "" { return 0 }
    let mut i = 0
    let mut neg = false
    if t.slice(0, 1) == "-" { neg = true; i = 1 }
    let mut n = 0
    while i < len(t) {
        let ch = t.slice(i, i + 1)
        if ch >= "0" && ch <= "9" {
            let code = ch.byte_at(0)
            n = n * 10 + (code - 48)
        } else {
            break
        }
        i = i + 1
    }
    if neg { return 0 - n }
    return n
}

@pure_fn
fn _kernel_to_str(k: array) -> str {
    return to_string(k[0]) + "," + to_string(k[1]) + "," + to_string(k[2]) + "," + to_string(k[3])
}

fn selftest() -> int {
    let mut fails = 0
    println("[akida_delta_feedback selftest — DESIGN-TIER mock]")

    // F1: extract_witness_verdict — full PASS witness
    let w_pass = "{\"tier1\":\"PASS\",\"axes\":{\"axis_a\":{\"summary\":\"x\"},\"axis_b\":{\"summary\":\"y\"}},\"correlation_estimate\":0.42,\"falsifiers\":\"F1=PASS,F2=PASS,F3=PASS,F4=PASS\"}"
    let v1 = extract_witness_verdict(w_pass)
    if v1[0] == 1 && v1[1] >= 3 && v1[2] >= 80 {
        println("  PASS F1 extract pass-witness q=" + to_string(v1[2]))
    } else {
        println("  FAIL F1 extract pass-witness (tier1=" + to_string(v1[0]) + " fp=" + to_string(v1[1]) + " q=" + to_string(v1[2]) + ")"); fails = fails + 1
    }

    // F2: extract — empty
    let v2 = extract_witness_verdict("")
    if v2[0] == 0 && v2[1] == 0 && v2[2] == 0 {
        println("  PASS F2 extract empty safety")
    } else {
        println("  FAIL F2 extract empty safety"); fails = fails + 1
    }

    // F3: compute_kernel_adjustments — fail tier1 → axis_seed_d > 0
    let v_fail = [0, 1, 30]
    let prev = [50, 700, 100, 30]
    let d3 = compute_kernel_adjustments(v_fail, prev)
    if d3[0] > 0 && d3[3] > 0 {
        println("  PASS F3 fail-tier1 strengthen axis+dup_pen")
    } else {
        println("  FAIL F3 fail-tier1 strengthen axis+dup_pen d=" + to_string(d3[0]) + "," + to_string(d3[3])); fails = fails + 1
    }

    // F4: compute — high quality + PASS → relax dup_pen
    let v_good = [1, 4, 90]
    let d4 = compute_kernel_adjustments(v_good, prev)
    if d4[3] < 0 {
        println("  PASS F4 high-quality relax dup_pen")
    } else {
        println("  FAIL F4 high-quality relax dup_pen d=" + to_string(d4[3])); fails = fails + 1
    }

    // F5: _apply_kernel_diff
    let new = _apply_kernel_diff([50, 700, 100, 30], [5, -50, 10, 0])
    if new[0] == 55 && new[1] == 650 && new[2] == 110 && new[3] == 30 {
        println("  PASS F5 apply_kernel_diff")
    } else {
        println("  FAIL F5 apply_kernel_diff"); fails = fails + 1
    }

    // F6: io_seam — retune with mock witness file
    let tmp_w = "/tmp/akida_delta_feedback_witness.json"
    let tmp_k = "/tmp/akida_delta_feedback_kernel.txt"
    let _w = exec("printf '%s' '{\"tier1\":\"PASS\",\"axis_a\":\"x\",\"axis_b\":\"y\",\"summary\":\"s\",\"correlation_estimate\":0.42,\"falsifiers\":\"F1=PASS,F2=PASS,F3=PASS\"}' > " + tmp_w)
    let _k = exec("printf '%s' '50,700,100,30' > " + tmp_k)
    let r6 = retune_kernel(tmp_w, tmp_k)
    let new_kernel_str = to_string(r6[0])
    if new_kernel_str != "NO_WITNESS" && new_kernel_str.contains(",") {
        println("  PASS F6 retune mock new_kernel=" + new_kernel_str)
    } else {
        println("  FAIL F6 retune mock"); fails = fails + 1
    }

    // F7: 5-cycle simulation — kernel converges (dup_pen non-decreasing for failures)
    let mut k = [50, 700, 100, 30]
    let mut cycle = 0
    let mut dup_at_start = k[3]
    while cycle < 5 {
        // Mix of fail/pass — 3 fails then 2 passes.
        let v = if cycle < 3 { [0, 1, 30] } else { [1, 4, 90] }
        let d = compute_kernel_adjustments(v, k)
        k = _apply_kernel_diff(k, d)
        cycle = cycle + 1
    }
    // After failures+passes mix, dup_pen should have moved away from start.
    if k[3] != dup_at_start {
        println("  PASS F7 5-cycle simulation final_kernel=" + _kernel_to_str(k))
    } else {
        println("  FAIL F7 5-cycle simulation kernel unchanged"); fails = fails + 1
    }

    // F8: missing-file safety
    let r8 = retune_kernel("/tmp/nonexistent-akida-delta-witness.json", "/tmp/nonexistent-kernel.txt")
    if to_string(r8[0]) == "NO_WITNESS" {
        println("  PASS F8 missing-witness safety")
    } else {
        println("  FAIL F8 missing-witness safety"); fails = fails + 1
    }

    if fails == 0 { println("[akida_delta_feedback] OK 8/8"); return 0 }
    println("[akida_delta_feedback] FAIL " + to_string(fails) + "/8")
    return 1
}

fn main() -> int {
    let args = std::env::args()
    if len(args) >= 2 && args[1] == "--selftest" { return selftest() }
    if len(args) >= 6 && args[1] == "--retune" {
        let mut wp = ""
        let mut kp = ""
        let mut i = 2
        while i < len(args) {
            if args[i] == "--witness" && i + 1 < len(args) { wp = args[i + 1] }
            if args[i] == "--kernel" && i + 1 < len(args) { kp = args[i + 1] }
            i = i + 1
        }
        let r = retune_kernel(wp, kp)
        println("new_kernel=" + to_string(r[0]))
        return 0
    }
    eprintln("usage: hexa run tool/akida_delta_feedback.hexa --selftest")
    eprintln("       hexa run tool/akida_delta_feedback.hexa --retune --witness <p> --kernel <p>")
    return 2
}
